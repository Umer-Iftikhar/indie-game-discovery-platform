@model IndieVault.Models.Game
@using System.Security.Claims

@{
    ViewData["Title"] = Model?.Title ?? "Game Details";
}


<div class="container mt-5 pb-5">
    <div class="row">
        <!-- Sidebar: Left Column (md-4) -->
        <div class="col-md-4 mb-4">
            <div class="iv-sticky-column">
            <div class="iv-details-sidebar">
                <img src="@Model.CoverImagePath" class="img-fluid rounded-4 shadow-lg mb-4" alt="Cover for @Model.Title" />
                <div class="iv-sidebar-content">
                    <h2 class="fw-bold mb-1">@Model.Title</h2>
                    <p class="iv-text-dim small mb-4">
                        <i class="bi bi-person-badge me-1"></i> Developed by:
                        <strong>
                            <a asp-controller="Account" asp-action="Profile" asp-route-userId="@Model.DeveloperId" class="iv-link-highlight">
                                @Model.Developer?.UserName
                            </a>
                        </strong>
                    </p>
                    
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="iv-price-tag mb-0">@(Model.Price == 0 ? "Free" : $"${Model.Price}")</h3>
                        <span class="iv-badge-glass">
                            <i class="bi bi-controller me-1"></i> @Model.Genre?.Name
                        </span>
                    </div>

                    <div class="d-grid gap-3">
                        <div class="d-grid gap-2">
                            @if (!string.IsNullOrEmpty(Model.DownloadLink))
                            {
                                <form asp-controller="Download" asp-action="Download" asp-route-id="@Model.Id" method="post">
                                    <button type="submit" class="iv-btn-primary w-100">
                                        <i class="bi bi-download me-2"></i> Get Game
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button class="iv-btn-disabled" disabled>
                                    <i class="bi bi-clock-history me-2"></i> Coming Soon
                                </button>
                            }
                            
                            @if (User.Identity!.IsAuthenticated && ViewBag.IsPlayer == true)
                            {
                                <button id="wishlistBtn"
                                        data-game-id="@Model.Id"
                                        data-wishlisted="@ViewBag.IsWishlisted.ToString().ToLower()"
                                        class="iv-btn-wishlist @(ViewBag.IsWishlisted ? "active" : "")">
                                    <i class="bi @(ViewBag.IsWishlisted ? "bi-heart-fill" : "bi-heart") me-2"></i>
                                    <span id="wishlistText">@(ViewBag.IsWishlisted ? "In Wishlist" : "Add to Wishlist")</span>
                                </button>
                            }
                        </div>
                        <a asp-controller="Home" asp-action="Index" class="iv-btn-back">
                            <i class="bi bi-arrow-left me-1"></i> Back to Library
                        </a>
                    </div>
                </div>
            </div>
                
            <!-- Specification Container -->
            <div class="spec-container mt-4 shadow-lg">
                <h6 class="spec-header"><i class="bi bi-info-circle me-2"></i>Specifications</h6>
                <p class="mb-2 small"><span class="spec-label">Engine:</span> <span class="spec-value">@(Model.Engine?.Name ?? "Custom")</span></p>
                <p class="mb-3 small"><span class="spec-label">Released:</span> <span class="spec-value">@Model.ReleaseDate.ToString("MMM dd, yyyy")</span></p>

                <h6 class="spec-label-header small">Platforms</h6>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var gp in Model.GamePlatforms)
                    {
                        <span class="iv-badge-dark">@gp.Platform.Name</span>
                    }
                </div>
            </div>
            </div>
        </div>

        <!-- Main Content: Right Column (md-8) -->
        <div class="col-md-8">
            @if (Model.Screenshots != null && Model.Screenshots.Any())
            {
                <div class="screenshot-scroll mb-2">
                    @foreach (var screen in Model.Screenshots)
                    {
                        <div class="screenshot-item">
                            <a href="@screen.ImagePath" target="_blank">
                                <img src="@screen.ImagePath" alt="Gameplay Screenshot" class="rounded-3 shadow" />
                            </a>
                        </div>
                    }
                </div>
                <div class="text-center mb-4">
                    <small class="iv-text-dim"><i class="bi bi-arrows-expand me-1"></i> Scroll to see more</small>
                </div>
            }

            <div class="iv-card-glass mb-4 p-4">
                <h4 class="fw-bold iv-border-bottom pb-2">About the Game</h4>
                <div class="game-description mt-3 iv-text-description">
                    @Model.Description
                </div>

                <div class="mt-4">
                    @foreach (var gt in Model.GameTags)
                    {
                        <span class="iv-tag-pill">#@gt.Tag.Name</span>
                    }
                </div>
            </div>

            <!-- Reviews Section -->
            <div class="iv-card-glass p-4">
                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold">
                        <i class="bi bi-chat-left-text me-2"></i>Reviews
                        <span class="iv-text-dim fw-normal ms-1">(@(Model.Reviews?.Count ?? 0))</span>
                    </h4>

                    @if (User.Identity.IsAuthenticated && ViewBag.IsPlayer == true && Model.DeveloperId != User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier))
                    {
                        if (ViewBag.HasReviewed == true)
                        {
                            <span class="iv-badge-success">
                                <i class="bi bi-check-circle me-1"></i> You've reviewed this!
                            </span>
                        }
                        else
                        {
                            <a asp-controller="Review" asp-action="Create" asp-route-id="@Model.Id" class="iv-btn-primary btn-sm px-4">Write a Review</a>
                        }
                    }
                </div>

                @if (Model.Reviews != null && Model.Reviews.Any())
                {
                    @foreach (var review in Model.Reviews)
                    {
                        <div class="iv-review-item mb-3">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-0 fw-bold">@review.User?.UserName</h6>
                                    <div class="text-warning small my-1">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                        }
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <small class="iv-text-dim">
                                        <i class="bi bi-calendar3 me-1"></i> @review.ReviewDate.ToString("MMM dd, yyyy")
                                    </small>
                                    @if (User.Identity.IsAuthenticated && (User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier) == review.UserId || User.IsInRole("Admin")))
                                    {
                                        <form asp-controller="Review" asp-action="Delete" asp-route-id="@review.Id" method="post"
                                              onsubmit="return confirm('Are you sure you want to delete this review?');">
                                            <button type="submit" class="btn btn-link text-danger p-0 border-0 ms-2" title="Delete Review">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </div>
                            <p class="mt-2 mb-0 iv-text-description">@review.Comment</p>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 iv-empty-state">
                        <p class="iv-text-dim mb-0">No reviews yet. Be the first to play and leave your feedback!</p>
                    </div>
                }
            </div>
        </div>
    </div> <!-- End Row -->
</div> <!-- End Container -->

@Html.AntiForgeryToken()

