@model IndieVault.Models.Game
@using System.Security.Claims

@{
    ViewData["Title"] = Model?.Title ?? "Game Details";
}

<style>
    /* Horizontal Scroll Gallery Styles */
    .screenshot-scroll {
        display: flex;
        overflow-x: auto;
        gap: 15px;
        scroll-snap-type: x mandatory;
        background: #121212; /* Dark background like a cinema/Steam */
        padding: 15px;
        border-radius: 12px;
    }

    .screenshot-item {
        flex: 0 0 100%; /* Shows exactly one screenshot at a time */
        scroll-snap-align: center;
        display: flex;
        justify-content: center;
        align-items: center;
    }

        .screenshot-item img {
            max-width: 100%;
            max-height: 500px;
            object-fit: contain; /* Prevents stretching or cropping */
            border-radius: 4px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

    /* Custom Scrollbar for the gallery */
    .screenshot-scroll::-webkit-scrollbar {
        height: 8px;
    }

    .screenshot-scroll::-webkit-scrollbar-track {
        background: #222;
        border-radius: 10px;
    }

    .screenshot-scroll::-webkit-scrollbar-thumb {
        background: #555;
        border-radius: 10px;
    }

        .screenshot-scroll::-webkit-scrollbar-thumb:hover {
            background: #777;
        }
</style>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm border-0">
                <img src="@Model.CoverImagePath" class="card-img-top rounded shadow" alt="Cover for @Model.Title" />
                <div class="card-body">
                    <h2 class="h4 fw-bold mb-1">@Model.Title</h2>
                    <p class="text-muted small">
                        <i class="bi bi-person-badge me-1"></i> Developed by: <strong>
                        <a asp-controller="Account" asp-action="Profile" asp-route-userId="@Model.DeveloperId" class="text-decoration-none">
                            @Model.Developer?.UserName
                        </a>
                    </strong>
                    </p>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="text-success fw-bold mb-0">
                            @(Model.Price == 0 ? "Free" : $"${Model.Price}")
                        </h4>
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-controller me-1"></i> @Model.Genre?.Name
                        </span>
                    </div>

                    <div class="d-grid gap-2">
                        <div class="d-grid gap-2">
                            @if (!string.IsNullOrEmpty(Model.DownloadLink))
                            {
                                @* This is now an actual link (<a>) styled to look like your button *@
                                <a href="@Model.DownloadLink"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-primary btn-lg rounded-pill">
                                    <i class="bi bi-download me-2"></i> Get Game
                                </a>
                            }
                            else
                            {
                                @* If the developer hasn't provided a link, show this instead *@
                                <button class="btn btn-secondary btn-lg rounded-pill" disabled>
                                    <i class="bi bi-clock-history me-2"></i> Coming Soon
                                </button>
                            }
                            
                            @* --- WISHLIST BUTTON START --- *@
                            @if (User.Identity!.IsAuthenticated && ViewBag.IsPlayer == true)
                            {
                                <button id="wishlistBtn"
                                        data-game-id="@Model.Id"
                                        data-wishlisted="@ViewBag.IsWishlisted.ToString().ToLower()"
                                        class="btn @(ViewBag.IsWishlisted ? "btn-danger" : "btn-outline-danger") btn-lg rounded-pill">
                                    <i class="bi @(ViewBag.IsWishlisted ? "bi-heart-fill" : "bi-heart") me-2"></i>
                                    <span id="wishlistText">@(ViewBag.IsWishlisted ? "In Wishlist" : "Add to Wishlist")</span>
                                </button>
                            }
                            
                            
                            @* --- WISHLIST BUTTON END --- *@
                        </div>
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm border-0">
                            <i class="bi bi-arrow-left me-1"></i> Back to Library
                        </a>
                    </div>
                </div>
            </div>

            <div class="mt-4 p-3 bg-light rounded border shadow-sm">
                <h6 class="fw-bold mb-3"><i class="bi bi-info-circle me-2"></i>Specifications</h6>
                <p class="mb-2 small"><strong>Engine:</strong> @(Model.Engine?.Name ?? "Custom")</p>
                <p class="mb-3 small"><strong>Released:</strong> @Model.ReleaseDate.ToString("MMM dd, yyyy")</p>

                <h6 class="fw-bold mb-2 small">Platforms</h6>
                @foreach (var gp in Model.GamePlatforms)
                {
                    <span class="badge bg-dark me-1 mb-1">@gp.Platform.Name</span>
                }
            </div>
        </div>

        <div class="col-md-8">
            @if (Model.Screenshots != null && Model.Screenshots.Any())
            {
                <div class="screenshot-scroll mb-2">
                    @foreach (var screen in Model.Screenshots)
                    {
                        <div class="screenshot-item">
                            <a href="@screen.ImagePath" target="_blank" title="View Fullscreen">
                                <img src="@screen.ImagePath" alt="Gameplay Screenshot" />
                            </a>
                        </div>
                    }
                </div>
                <div class="text-center mb-4">
                    <small class="text-muted"><i class="bi bi-arrows-expand me-1"></i> Scroll to see more screenshots</small>
                </div>
            }

            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">
                    <h4 class="fw-bold border-bottom pb-2">About the Game</h4>
                    <p class="mt-3 text-secondary" style="white-space: pre-line; line-height: 1.7;">
                        @Model.Description
                    </p>

                    <div class="mt-4">
                        @foreach (var gt in Model.GameTags)
                        {
                            <span class="badge rounded-pill bg-light text-secondary border me-1">#@gt.Tag.Name</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 pb-5">
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h4 class="fw-bold"><i class="bi bi-chat-left-text me-2"></i>Reviews (@Model.Reviews?.Count)</h4>

            @* Prevent owner from reviewing their own game *@
            @if (User.Identity.IsAuthenticated && ViewBag.IsPlayer == true && Model.DeveloperId != User.FindFirstValue(ClaimTypes.NameIdentifier))
            {
                if (ViewBag.HasReviewed == true)
                {
                    <span class="badge bg-success rounded-pill px-3 py-2">
                        <i class="bi bi-check-circle me-1"></i> You've reviewed this!
                    </span>
                }
                else
                {
                    <a asp-controller="Review"  asp-action="Create" asp-route-id="@Model.Id" class="btn btn-primary rounded-pill btn-sm px-4">Write a Review</a>
                }
            }
        </div>

        @if (Model.Reviews != null && Model.Reviews.Any())
        {
            @foreach (var review in Model.Reviews)
            {
                <div class="card mb-3 border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-0 fw-bold">@review.User?.UserName</h6>
                                <div class="text-warning small my-1">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi bi-star@(i <= review.Rating ? "-fill" : "")"></i>
                                    }
                                </div>
                            </div>
                            <small class="text-muted">
                                <i class="bi bi-calendar3 me-1"></i> @review.ReviewDate.ToString("MMM dd, yyyy")
                            </small>
                            @if (User.Identity.IsAuthenticated && (User.FindFirstValue(ClaimTypes.NameIdentifier) == review.UserId || User.IsInRole("Admin")))
                            {
                                <form asp-controller="Review" asp-action="Delete" asp-route-id="@review.Id" method="post"
                                      onsubmit="return confirm('Are you sure you want to delete this review?');">
                                    <button type="submit" class="btn btn-link text-danger p-0 border-0 ms-2" title="Delete Review">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                        </div>
                        <p class="mt-2 mb-0 text-secondary">@review.Comment</p>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-4 bg-light rounded border">
                <p class="text-muted mb-0">No reviews yet. Be the first to play and leave your feedback!</p>
            </div>
        }
    </div>
</div>
@Html.AntiForgeryToken()

<script>
    document.getElementById('wishlistBtn').addEventListener('click', async function(event)
    {
        try
        {
            // 1. Get both the ID and the current status separately
            const btn = event.currentTarget;
            const gameId = btn.dataset.gameId;
            const isWishlisted = btn.dataset.wishlisted === 'true';

            // 2. Get the antiforgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            // 3. Determine URL based on current state
            const url = isWishlisted ? '/Wishlist/Remove' : '/Wishlist/Add';

            // 4. Send fetch() POST to correct URL
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'RequestVerificationToken': token
                },
                body: JSON.stringify({ gameId: gameId }),
            });
            // 5. Read JSON response
            const result = await response.json();

            // 6. Update button based on success/failure
            if(response.ok && result.success)
            {
                btn.dataset.wishlisted = (!isWishlisted).toString();
                btn.classList.toggle('btn-danger', !isWishlisted);
                btn.classList.toggle('btn-outline-danger', isWishlisted);
                btn.querySelector('i').classList.toggle('bi-heart-fill', !isWishlisted);
                btn.querySelector('i').classList.toggle('bi-heart', isWishlisted);
                btn.querySelector('#wishlistText').textContent = !isWishlisted ? 'In Wishlist' : 'Add to Wishlist';
            }
            else
            {
                alert(result.message || 'An error occurred while updating your wishlist. Please try again.');
            }
        }
         catch(error) 
         {
            console.error('Error updating wishlist:', error);
            alert('An unexpected error occurred. Please try again later.');
         }

    });
</script>