@model IEnumerable<IndieVault.Models.Game>

@{
    ViewData["Title"] = "My Games";
}

<div class="dashboard-wrapper">
    <div class="dashboard-header">
        <h2 class="dashboard-title">@ViewData["Title"]</h2>
        <div class="header-actions">
            <a asp-controller="Game" asp-action="Upload" class="primary-button btn-small">
                <i class="bi bi-plus-lg"></i> Upload New Game
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state-card">
            <i class="bi bi-controller"></i>
            <h4>No games found!</h4>
            <p>Ready to share your creation with the world?</p>
            <a asp-controller="Game" asp-action="Upload" class="primary-button">Start Uploading</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="dashboard-table">
                <thead>
                    <tr>
                        <th>Cover</th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Engine</th>
                        <th>Price</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var game in Model)
                    {
                        <tr>
                            <td>
                                <img src="@($"{game.CoverImagePath}?v={DateTime.UtcNow.Ticks}")" alt="Cover" class="table-game-cover" />
                            </td>
                            <td class="fw-bold text-white">@game.Title</td>
                            <td><span class="badge-dark">@game.Genre?.Name</span></td>
                            <td class="text-muted">@game.Engine?.Name</td>
                            <td class="text-accent">@(game.Price == 0 ? "Free" : $"${game.Price}")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-controller="Game" asp-action="Details" asp-route-id="@game.Id" class="action-link info" title="View">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-controller="Game" asp-action="Edit" asp-route-id="@game.Id" class="action-link warning" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <form asp-controller="Game" asp-action="Delete" asp-route-id="@game.Id" method="post"
                                          onsubmit="return confirm('Permanently delete this game?')">
                                        <button type="submit" class="action-link danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>