@model IndieVault.ViewModels.GenreViewModel

@{
    ViewData["Title"] = "Create Genre";
}

<div class="dashboard-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="admin-panel shadow-lg">
                <div class="admin-panel-header">
                    <h5 class="mb-0">
                        <i class="bi bi-plus-circle-fill text-primary me-2"></i>@ViewData["Title"]
                    </h5>
                </div>
                <div class="admin-panel-body p-4">
                    <form asp-action="CreateGenre" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert-dark-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="GenreName" class="stats-label mb-2 d-block">Genre Name</label>
                            <div class="custom-input-group">
                                <span class="input-icon"><i class="bi bi-tag"></i></span>
                                <input asp-for="GenreName" class="form-control-dark" placeholder="e.g. RPG, Horror, Platformer" />
                            </div>
                            <span asp-validation-for="GenreName" class="text-danger small mt-1 d-block"></span>
                        </div>

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-controller="Admin" asp-action="Dashboard" class="text-muted text-decoration-none hover-white">
                                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                            </a>
                            <button type="submit" class="primary-button btn-small">
                                <i class="bi bi-save me-1"></i> Save Genre
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}