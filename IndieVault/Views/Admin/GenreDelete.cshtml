@model IndieVault.ViewModels.GenreViewModel

@{
    ViewData["Title"] = "Delete Genre";
}

<div class="dashboard-wrapper">
    <div class="row justify-content-center">
        <div class="col-md-6">
            @* The panel replaces the card for a more professional, integrated look *@
            <div class="admin-panel border-danger border-opacity-25">
                <div class="admin-panel-header bg-danger bg-opacity-10">
                    <h5 class="text-danger mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion
                    </h5>
                </div>
                <div class="admin-panel-body p-4">
                    
                    @* Error Alert - styled to match your dark theme *@
                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="alert-dark-danger mb-4">
                            <i class="bi bi-slash-circle-fill me-2"></i>
                            <span>@Model.Message</span>
                        </div>
                    }

                    <p class="text-white fs-5">
                        Are you sure you want to delete the genre: <strong class="text-danger">@Model.GenreName</strong>?
                    </p>
                    
                    <div class="info-note mb-4">
                        <i class="bi bi-info-circle me-1"></i> This action cannot be undone.
                    </div>

                    <form asp-controller="Admin" asp-action="GenreDelete" method="post">
                        <input type="hidden" asp-for="GenreId" />
                        <input type="hidden" asp-for="GenreName" />

                        <div class="d-flex justify-content-between align-items-center mt-5">
                            <a asp-action="Dashboard" class="text-muted text-decoration-none hover-white">
                                <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
                            </a>
                            
                            <button type="submit"
                                    class="primary-button bg-danger border-danger @(string.IsNullOrEmpty(Model.Message) ? "" : "disabled-btn")"
                                @(string.IsNullOrEmpty(Model.Message) ? "" : "disabled")>
                                <i class="bi bi-trash"></i> Confirm Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>