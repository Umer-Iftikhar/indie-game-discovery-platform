@model IndieVault.DTOs.GameBrowseDto

<div class="card h-100 iv-card border-0 shadow-sm rounded-4 overflow-hidden">
    @* Image Container with Fixed Ratio *@
    <div class="position-relative iv-card-img-container" style="aspect-ratio: 16/9; overflow: hidden; background: #000;">
        <img src="@Model.CoverImagePath"
             class="card-img-top iv-card-img h-100 w-100"
             style="object-fit: cover;"
             alt="@Model.Title">
        
        @* Genre Badge floating on image *@
        <div class="iv-card-badge position-absolute" style="top: 10px; left: 10px; z-index: 2;">
            <span class="badge rounded-pill bg-dark bg-opacity-75 backdrop-blur px-3 py-2">
                @Model.GenreName
            </span>
        </div>
    </div>

    @* Card Content *@
    <div class="card-body d-flex flex-column p-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title fw-bold mb-0 text-truncate" style="max-width: 75%;" title="@Model.Title">
                @Model.Title
            </h5>
            <div class="iv-card-rating px-2 py-1 rounded-3 bg-warning bg-opacity-10">
                <i class="bi bi-star-fill text-warning" style="font-size: 0.85rem;"></i>
                <span class="small fw-bold ms-1">@Model.AverageRatings.ToString("0.0")</span>
            </div>
        </div>

        <p class="text-muted small mb-3">By <span class="text-secondary fw-semibold">@Model.Developer</span></p>

        <div class="mt-auto d-flex align-items-center justify-content-between pt-3 border-top border-white border-opacity-10">
            <div class="iv-card-price fw-bold text-info fs-5">
                @(Model.Price == 0 ? "FREE" : $"${Model.Price}")
            </div>
            <a asp-controller="Game" asp-action="Details" asp-route-id="@Model.Id"
                   class="btn btn-sm btn-dark px-3 rounded-pill fw-bold iv-btn-details">
                Details
            </a>
        </div>
    </div>
</div>