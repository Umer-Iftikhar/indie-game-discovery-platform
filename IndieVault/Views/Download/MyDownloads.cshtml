@model IEnumerable<IndieVault.ViewModels.DownloadHistoryViewModel>

@{
    ViewData["Title"] = "My Downloads";
}

<style>
    .history-card {
        max-width: 900px;
        margin: 30px auto;
        padding: 20px;
        border: 1px solid #ddd;
        border-radius: 8px;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .history-title {
        border-bottom: 2px solid #333;
        padding-bottom: 10px;
        margin-bottom: 20px;
    }

    .data-table {
        width: 100%;
        border-collapse: collapse;
    }

    .data-table th {
        text-align: left;
        padding: 12px;
        background-color: #f4f4f4;
        border-bottom: 2px solid #ccc;
    }

    .data-table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
    }

    .data-table tr:hover {
        background-color: #fafafa;
    }

    .no-data {
        text-align: center;
        padding: 40px;
        color: #666;
        font-style: italic;
    }
</style>

<div class="history-card">
    <h2 class="history-title">Download History</h2>

    @if (Model != null && Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Game Name</th>
                    <th>Downloaded At</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Game" asp-action="Details" asp-route-id="@item.GameId" class="game-link">
                                <strong>@item.GameName</strong>
                            </a>
                        </td>
                        <td>@item.DownloadTime.ToString("dd MMM yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="no-data">
            <p>No download history found for your account.</p>
        </div>
    }
</div>