@model IEnumerable<IndieVault.ViewModels.DownloadHistoryViewModel>

@{
    ViewData["Title"] = "My Downloads";
}

<div class="dashboard-wrapper">
    <div class="dashboard-header">
        <h2 class="dashboard-title">@ViewData["Title"]</h2>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="dashboard-table">
                <thead>
                    <tr>
                        <th>Game Name</th>
                        <th>Downloaded At</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">
                                <a asp-controller="Game" asp-action="Details" asp-route-id="@item.GameId" class="text-white text-decoration-none hover-blue">
                                    @item.GameName
                                </a>
                            </td>
                            <td class="text-muted">@item.DownloadTime.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-controller="Game" asp-action="Details" asp-route-id="@item.GameId" class="action-link info" title="View Game">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state-card">
            <i class="bi bi-cloud-download text-muted display-4"></i>
            <h4 class="text-white mt-3">No history found</h4>
            <p class="text-muted">You haven't downloaded any games yet.</p>
            <a asp-controller="Home" asp-action="Index" class="primary-button mt-2">Browse Games</a>
        </div>
    }
</div>