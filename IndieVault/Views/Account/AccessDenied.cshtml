@{
    ViewData["Title"] = "Access Denied";
}

<main class="auth-container">
    <section class="auth-card text-center">
        <div class="icon-wrapper">
            <i class="bi bi-shield-lock-fill text-danger"></i>
        </div>
        
        <h1 class="error-code">403</h1>
        <h2 class="auth-title">Restricted Access</h2>
        
        @if (User.Identity?.IsAuthenticated == true)
        {
            <p class="field-help">
                Hello <strong>@User.Identity.Name</strong>, you are signed in,
                but you do not have the <strong>Permissions</strong> required to access this section.
            </p>
            
            <div class="button-group">
                <a asp-controller="Home" asp-action="Index" class="primary-button">
                    <i class="bi bi-house-door"></i> Return Home
                </a>

                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="outline-button-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout & Switch Account
                    </button>
                </form>
            </div>
        }
        else
        {
            <p class="field-help">
                You need to be logged in to view this page.
            </p>
            <a asp-area="Identity" asp-page="/Account/Login" class="primary-button">
                Login
            </a>
        }
    </section>
</main>