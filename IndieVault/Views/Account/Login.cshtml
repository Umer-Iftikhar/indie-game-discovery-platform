
@using IndieVault.ViewModels;
@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<div class="login-container">
    <h2>@ViewData["Title"]</h2>

    <form asp-controller="Account" asp-action="Login" method="post" class="custom-form">
        <div asp-validation-summary="ModelOnly" class="error-text"></div>

        <div class="field-group">
            <label asp-for="Email" class="field-label"></label>
            <input asp-for="Email" class="input-field" />
            <span asp-validation-for="Email" class="error-text"></span>
        </div>

        <div class="field-group">
            <label asp-for="Password" class="field-label"></label>
            <input asp-for="Password" class="input-field" />
            <span asp-validation-for="Password" class="error-text"></span>
        </div>

        <div class="checkbox-group">
            <input asp-for="RememberMe" type="checkbox" />
            <label asp-for="RememberMe"></label>
        </div>

        <button type="submit" class="primary-button">Login</button>
    </form>
</div>