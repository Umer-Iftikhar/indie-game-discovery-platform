@model IndieVault.ViewModels.EditProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="mb-4">Edit Profile</h2>

            <form asp-action="EditProfile" method="post" class="card shadow-sm">
                <div class="card-body">
                    @* Anti-forgery token is automatically injected by the form tag helper *@
                    
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="GithubUserName" class="form-control-label fw-bold">GitHub Username</label>
                        <div class="input-group">
                            <span class="input-group-text">github.com/</span>
                            <input asp-for="GithubUserName" class="form-control" placeholder="username" />
                        </div>
                        <span asp-validation-for="GithubUserName" class="text-danger small"></span>
                        <div class="form-text">Enter your GitHub username to link your repositories.</div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <button type="submit" class="btn btn-primary">Save Changes</button>
                        
                        @* Assuming the user's ID is needed for the profile link.
                           If you don't have it in the VM, you can get it from the User claims. *@
                        <a asp-action="Profile"
                               asp-route-userId="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value"
                               class="btn btn-link text-secondary text-decoration-none">
                            Cancel
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}